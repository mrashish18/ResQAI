# Environment Variables

# Database
DATABASE_URL=postgresql://resqai_user:your_password@localhost:5432/resqai

# For SQLite (development, no Postgres needed)
# DATABASE_URL=sqlite:///./resqai.db

# Security
SECRET_KEY=your-super-secret-jwt-key-change-in-production-minimum-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# App
ENVIRONMENT=development

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80
